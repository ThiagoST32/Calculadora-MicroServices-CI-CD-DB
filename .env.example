#Valor padrão para que a aplicação possa se comunicar com o Vault
VAULT_APPLICATION_ADDR=http://vault-calc:8200
#Valor padrão para que o script interno possa rodar e criar as credenciais
VAUULT_INTERNAL_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=<SEU-VAULT-TOKEN>
MYSQL_PASSWORD_ROOT=<SUA-SENHA-ROOT>
MYSQL_ROOT_HOST=<HOST-DO-ROOT-PADRÃO-%>